# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Populated by bin/setup.sh (safe to re-run; existing IDs are reused) ──────
AGENT_DEAL_TEAM_ID=agent_...
AGENT_SUB_0_ID=agent_...
AGENT_SUB_1_ID=agent_...
AGENT_SUB_2_ID=agent_...
AGENT_SUB_3_ID=agent_...
AGENT_SUB_IDS=
ENVIRONMENT_ID=env_...
MEMORY_STORE_ID=memstore_...
FILE_IDS=file_...,file_...,file_...    # acme, bridgewell, norwood financials

# ─── Optional: Linear via MCP + Vault ─────────────────────────────────────────

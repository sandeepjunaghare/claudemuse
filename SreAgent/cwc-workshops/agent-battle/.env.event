# Event configuration — the facilitator fills this in and commits it
# before the event so participants need zero manual URL setup.
# setup.sh reads it; shell exports override it.
#
# EVENT_URL is the deployed event server (see event/README.md). One URL
# provides the leaderboard, the wiki MCP, and the bot relay:
#   leaderboard  $EVENT_URL/api        wiki MCP   $EVENT_URL/wiki/mcp
#   bot relay    $EVENT_URL/relay/ws   admin      $EVENT_URL/admin
#
# Leave EVENT_URL empty (or delete this file) for solo / at-home practice:
# setup.sh then runs a local event server and one quick-tunnel instead.
